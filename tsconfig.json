{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "k6"],
    "skipLibCheck": true
  },
  "include": ["app/**/*.ts", "src/**/*.ts", "tests/**/*.ts"]
}